{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "namespace": {
            "type": "object",
            "properties": {
                "create": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                },
                "pullPolicy": {
                    "type": "string"
                }
            }
        },
        "replicaCount": {
            "type": "integer"
        },
        "podAnnotations": {
            "type": "object"
        },
        "controller": {
            "type": "object",
            "properties": {
                "leaderElect": {
                    "type": "boolean"
                },
                "extensions": {
                    "type": "boolean"
                },
                "extraArgs": {
                    "type": "array"
                }
            }
        },
        "resources": {
            "type": "object"
        },
        "podSecurityContext": {
            "type": ["object", "null"]
        },
        "containerSecurityContext": {
            "type": ["object", "null"]
        },
        "nodeSelector": {
            "type": "object"
        },
        "tolerations": {
            "type": "array"
        },
        "affinity": {
            "type": "object"
        }
    }
}
